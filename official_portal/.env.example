# Official Portal Environment Variables
# Copy this file to .env and fill in the values

# API URL
# Local Development
VITE_API_URL=http://localhost:5000/api

# Production (Vercel)
# VITE_API_URL=https://api.gryork.com/api

# Discovery Portal URL
# Local Development
# VITE_DISCOVERY_PORTAL_URL=http://localhost:5180

# Production
VITE_DISCOVERY_PORTAL_URL=https://discovery.gryork.com
