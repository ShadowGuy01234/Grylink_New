# Gryork Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/gryork
# Optional: comma-separated DNS servers used when mongodb+srv lookups fail in Node
# Example: MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4
MONGODB_DNS_SERVERS=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (for sending GryLink emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Gryork <noreply@gryork.com>

# ========================================
# Frontend Portal URLs (Production)
# ========================================
# Vercel Deployment URLs:
#   - gryork-public.vercel.app     : Public Marketing Website
#   - app-gryork.vercel.app        : Sub-Contractor Portal
#   - link-gryork.vercel.app       : GryLink Onboarding Portal
#   - partner-gryork.vercel.app    : Partner Portal (EPC & NBFC)
#   - official-gryork.vercel.app   : Official Portal (Sales, Ops, Admin)
#   - grylink-backend.vercel.app   : Backend API

# Vercel Production URLs
PUBLIC_SITE_URL=https://gryork-public.vercel.app
SUBCONTRACTOR_PORTAL_URL=https://app-gryork.vercel.app
GRYLINK_PORTAL_URL=https://link-gryork.vercel.app
PARTNER_PORTAL_URL=https://partner-gryork.vercel.app
OFFICIAL_PORTAL_URL=https://official-gryork.vercel.app

# Custom Domain URLs (Future)
# PUBLIC_SITE_URL=https://gryork.com
# SUBCONTRACTOR_PORTAL_URL=https://app.gryork.com
# GRYLINK_PORTAL_URL=https://link.gryork.com
# PARTNER_PORTAL_URL=https://partner.gryork.com
# ADMIN_PORTAL_URL=https://admin.gryork.com

# ========================================
# Development URLs (Local)
# ========================================
# PUBLIC_SITE_URL=http://localhost:5176
# SUBCONTRACTOR_PORTAL_URL=http://localhost:5173
# GRYLINK_PORTAL_URL=http://localhost:5174
# PARTNER_PORTAL_URL=http://localhost:5175
# OFFICIAL_PORTAL_URL=http://localhost:5177

# Legacy env vars (backward compatibility)
GRYLINK_FRONTEND_URL=https://link-gryork.vercel.app
ADMIN_PORTAL_URL=https://official-gryork.vercel.app

# Public Site Production URLs
# This powers API calls from Gryork public React app
# Example: https://grylink-backend.vercel.app/api
PUBLIC_API_BASE_URL=https://grylink-backend.vercel.app/api

# ========================================
# RAG Chatbot (Groq + Pinecone)
# ========================================
GROQ_API_KEY=your-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_EMBEDDING_MODEL=llama-text-embed-v2

PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=gryork-rag
# Example host: your-index-name-xxxx.svc.aped-4627-b74a.pinecone.io
PINECONE_INDEX_HOST=your-index-host.svc.aped-4627-b74a.pinecone.io
PINECONE_NAMESPACE_PREFIX=gryork
PINECONE_TOP_K=6

RAG_MAX_CONTEXT_CHUNKS=6
RAG_SCORE_THRESHOLD=0.72

# Embedding provider behavior:
# - auto: prefer Hugging Face bge-m3 (if HF_TOKEN exists), then Groq, then local hash
# - huggingface: use HF Inference feature-extraction endpoint only
# - groq: use Groq embedding model only
# - local: always use local hash embedding
RAG_EMBEDDING_PROVIDER=huggingface
# Hugging Face Inference token (Inference Providers permission required)
HF_TOKEN=your-hf-token
HF_BASE_URL=https://router.huggingface.co
HF_EMBEDDING_MODEL=BAAI/bge-m3
# Optional rerank pass after Pinecone retrieval using HF sentenceSimilarity API
RAG_HF_RERANK_ENABLED=true
RAG_HF_RERANK_TOP_N=30
# Optional explicit local embedding dimension (defaults to Pinecone index dimension)
RAG_LOCAL_EMBED_DIM=1024

# Optional ingestion controls
RAG_INGEST_NAMESPACE=gryork-common
RAG_INGEST_EMBED_BATCH_SIZE=8
RAG_INGEST_CHUNK_SIZE=1700
RAG_INGEST_CHUNK_OVERLAP=180
